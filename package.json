{
  "name": "my-api-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "jest": {
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "module-alias": "^2.3.4",
    "mongoose": "^9.3.1",
    "morgan": "~1.9.1",
    "xlsx": "^0.18.5"
  },
  "_moduleAliases": {
    "@": "."
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}